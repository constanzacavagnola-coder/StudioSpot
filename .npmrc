# .npmrc — registro, auth y comportamiento de CLI (NO secretos en claro)
# En pnpm 11 las opciones propias de pnpm viven en pnpm-workspace.yaml.
registry=https://registry.npmjs.org/

# No encadenar pre/post scripts de los PROPIOS scripts del proyecto de forma implícita.
enable-pre-post-scripts=false

# Lockfile estricto: la CLI no debe "arreglar" el lockfile silenciosamente.
prefer-frozen-lockfile=true

# Si se usara registro privado con token, el token va por ENV, nunca hardcodeado:
# //registry.npmjs.org/:_authToken=${NPM_TOKEN}
